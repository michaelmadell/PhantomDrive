<Application x:Class="PhantomDrive.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PhantomDrive.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- === Converters ======================================= -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:DriveStatusToColorConverter x:Key="StatusToColor"/>
            <conv:DriveStatusToBackgroundConverter x:Key="StatusToBg"/>
            <conv:MediaTypeToIconConverter x:Key="MediaIcon"/>
            <conv:NullToVisibilityConverter x:Key="NullToVis"/>
            <conv:MediaTypeToDisplayConverter x:Key="MediaDisplay"/>

            <!-- === Colour palette =================================== -->
            <!-- Dark theme – warm charcoal with cool accent -->
            <Color x:Key="BgDark">#FFE8EAED</Color>
            <Color x:Key="BgCard">#ffffff</Color>
            <Color x:Key="BgCardHover">#FF0000</Color>
            <Color x:Key="BgInput">#FF0F1114</Color>
            <Color x:Key="Border">#FF2A2E37</Color>
            <Color x:Key="BorderHover">#FF3A3F4B</Color>
            <Color x:Key="TextPrimary">#000000</Color>
            <Color x:Key="TextSecondary">#1E1E1E</Color>
            <Color x:Key="TextMuted">#4A4A4A</Color>
            <Color x:Key="AccentBlue">#0061FF</Color>
            <Color x:Key="AccentGreen">#00FF5E</Color>
            <Color x:Key="AccentAmber">#FFA000</Color>
            <Color x:Key="AccentRed">#FF0000</Color>
            <Color x:Key="AccentPurple">#4E00FF</Color>

            <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
            <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
            <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}"/>
            <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
            <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHover}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
            <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource AccentAmber}"/>
            <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>

            <!-- === Typography ======================================= -->
            <FontFamily x:Key="UIFont">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>
            <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

            <!-- === Global styles ==================================== -->

            <!-- Rounded button -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                    <Setter TargetName="Bd" Property="Background" Value="#70000000"/>
                                    <Setter Property="Foreground" Value="#ffffff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF383D4A"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Rounded button -->
            <Style x:Key="ActionButtonBrowse" TargetType="Button">
                <Setter Property="Background" Value="#0FD"/>
                <Setter Property="Foreground" Value="#000"/>
                <Setter Property="BorderBrush" Value="#000"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                        Background="#1E000000"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                    <Setter TargetName="Bd" Property="Background" Value="#D0005EFF"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2048B1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Accent (primary) button -->
            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1797FF" Offset="0"/>
                            <GradientStop Color="#0020FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FF2563EB"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- Danger button -->
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
                <Setter Property="Background" Value="#2DFF4A4A"/>
                <Setter Property="BorderBrush" Value="#55EF4444"/>
                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
            </Style>

            <!-- ComboBox dark style -->
            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <!-- TextBlock presets -->
            <Style x:Key="Heading" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style x:Key="Subheading" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            </Style>

            <Style x:Key="Label" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>

            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
